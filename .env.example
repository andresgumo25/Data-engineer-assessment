# PostgreSQL credentials (copy to .env and fill values)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=jobs_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# dbt connection environment variables (optional - used in profiles.yml)
DBT_USER=${POSTGRES_USER}
DBT_PASSWORD=${POSTGRES_PASSWORD}
DBT_HOST=localhost
DBT_PORT=5432
DBT_DB=${POSTGRES_DB}
DBT_SCHEMA=public

# Example: set DBT_PROFILE to 'default' if using a custom profiles.yml
DBT_PROFILE=default
