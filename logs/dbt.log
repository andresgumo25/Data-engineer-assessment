/*
Staging model: normalize basic fields and cast JSON/text columns to jsonb where appropriate.
Assumes a source table raw.staging_jobs exists (created by ingest script for Postgres or user-loaded).
*/

select
  md5(coalesce(job_title, '') || '||' || coalesce(company_name, '') || '||' || coalesce(job_posted_date::text, '')) as job_id,
  job_title,
  job_title_short,
  company_name,
  job_location,
  job_country,
  job_via,
  job_schedule_type,
  case when job_work_from_home in (true, 'true', 't', '1', 1) then true else false end as job_work_from_home,
  job_posted_date::timestamp as job_posted_date,
  case when job_no_degree_mention in (true, 'true', 't', '1', 1) then true else false end as job_no_degree_mention,
  case when job_health_insurance in (true, 'true', 't', '1', 1) then true else false end as job_health_insurance,
  salary_rate::text as salary_rate,
  salary_year_avg::numeric as salary_year_avg,
  salary_hour_avg::numeric as salary_hour_avg,
  -- store skills and type_skills as jsonb if they are parseable
  (case when job_skills is null then null else job_skills::jsonb end) as job_skills,
  (case when job_type_skills is null then null else job_type_skills::jsonb end) as job_type_skills,
  search_location
from "jobs_db"."public"."staging_jobs"
  );
